# Markets Recon Pipeline Configuration
# Copy this file to .env and fill in your values

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/marketsrecon.db

# Blob storage path for PDFs (local filesystem for MVP)
BLOB_STORAGE_PATH=./data/pdfs

# Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key for embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: JSON logging for production (true/false)
LOG_JSON_FORMAT=false
