# Markets Recon Pipeline Configuration
# Copy this file to .env and fill in your values

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/marketsrecon.db

# Blob storage path for PDFs (local filesystem for MVP)
BLOB_STORAGE_PATH=./data/pdfs

# =============================================================================
# Embeddings
# =============================================================================

# Select embeddings provider: openai | deepinfra
EMBEDDINGS_PROVIDER=openai

# OpenAI embeddings (used when EMBEDDINGS_PROVIDER=openai)
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_EMBEDDINGS_DIMENSIONS=1536
OPENAI_API_KEY=sk-...

# DeepInfra embeddings (used when EMBEDDINGS_PROVIDER=deepinfra)
DEEPINFRA_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-4B
DEEPINFRA_EMBEDDINGS_BASE_URL=https://api.deepinfra.com/v1/openai

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OhMyGPT - Claude Haiku 4.5 (Metadata & Call Extraction)
OHMYGPT_API_KEY=your-ohmygpt-api-key

# MegaLLM - GPT-OSS-120b (Candidate Retrieval)
MEGALLM_API_KEY=your-megallm-api-key

# Nebius - GLM-4.5-Air (Verification & Summary Generation)
NEBIUS_API_KEY=your-nebius-api-key

# DeepInfra - Qwen3-235B (Tooltip & Tag Generation)
DEEPINFRA_API_KEY=your-deepinfra-api-key

# =============================================================================
# Logging
# =============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: JSON logging for production (true/false)
LOG_JSON_FORMAT=false
